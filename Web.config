<?xml version="1.0" encoding="utf-8"?>
<!--
  CCMR1013 - 案件明細 WebForm
  環境：.NET Framework 4.7.2 / ASP.NET Web Forms
  ORM  ：Oracle.ManagedDataAccess (ODP.NET Managed Driver)

  安裝 NuGet 套件：
    Install-Package Oracle.ManagedDataAccess -Version 23.4.0

  生產環境安全建議：
    1. 請勿將真實密碼提交至版控；使用 DPAPI 或環境變數管理機密。
    2. 可使用 aspnet_regiis -pe 對 connectionStrings 區段加密。
-->
<configuration>
  <connectionStrings>
    <!--
      請將下列連線字串替換為實際 Oracle 連線資訊：
        HOST        : Oracle 主機位址（例：db-server.internal）
        PORT        : Oracle 監聽埠（預設 1521）
        SERVICE_NAME: Oracle 服務名稱（例：ORCL）
        User Id     : 資料庫帳號
        Password    : 資料庫密碼（生產環境請使用加密設定或外部 Key Vault）
    -->
    <add name="OracleDB"
         connectionString="Data Source=(DESCRIPTION=(ADDRESS_LIST=(ADDRESS=(PROTOCOL=TCP)(HOST=YOUR_HOST)(PORT=1521)))(CONNECT_DATA=(SERVICE_NAME=YOUR_SERVICE)));User Id=YOUR_USER;Password=YOUR_PASSWORD;"
         providerName="Oracle.ManagedDataAccess.Client" />
  </connectionStrings>

  <appSettings>
    <!--
      檔案連結替換設定：
        FileShareRoot : 伺服器端 UNC 路徑前綴（需替換掉的部分）
        FileUrlBase   : 對外開放的 URL 前綴（用於替換後的下載連結）
    -->
    <add key="FileShareRoot" value="\\snas1\Server_Share\ECS\程式拋轉區\CCM\" />
    <add key="FileUrlBase"   value="openedge:10.5.0.54/CCM_FILE/" />
  </appSettings>

  <system.web>
    <!-- debug: 開發環境設為 true，部署至生產環境前請改為 false -->
    <compilation debug="false" targetFramework="4.7.2" />
    <httpRuntime targetFramework="4.7.2" enableVersionHeader="false" maxRequestLength="51200" />
    <globalization requestEncoding="utf-8" responseEncoding="utf-8" culture="zh-TW" uiCulture="zh-TW" />
    <!-- validateRequest 保持預設值 true；若特定頁面需關閉請在 <%@ Page %> 指引上設定 -->
  </system.web>

  <system.webServer>
    <validation validateIntegratedModeConfiguration="false" />
    <security>
      <requestFiltering>
        <requestLimits maxAllowedContentLength="52428800" />
      </requestFiltering>
    </security>
  </system.webServer>

  <runtime>
    <assemblyBinding xmlns="urn:schemas-microsoft-com:asm.v1">
      <dependentAssembly>
        <assemblyIdentity name="Oracle.ManagedDataAccess"
                          publicKeyToken="89b483f429c47342"
                          culture="neutral" />
        <bindingRedirect oldVersion="4.121.0.0 - 4.65535.65535.65535"
                         newVersion="4.122.23.1" />
      </dependentAssembly>
    </assemblyBinding>
  </runtime>
</configuration>
